digraph ERD {
  rankdir=TB;
  concentrate=true;
  graph [fontname="Helvetica", nodesep=0.5, ranksep=1.3, splines=polyline, bgcolor="white"];
  node [shape=plaintext, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9, fontcolor="#475569", color="#94a3b8", arrowhead=crow, arrowtail=none, dir=back];

  "users" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>users</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="name">name <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="username">username <font color="#64748b" point-size="10">varchar(50)</font></td></tr><tr><td align="left" port="password">password <font color="#64748b" point-size="10">varchar(255)</font></td></tr><tr><td align="left" port="full_name">full_name <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="student_number">student_number <font color="#64748b" point-size="10">varchar(20)</font></td></tr><tr><td align="left" port="gender">gender <font color="#64748b" point-size="10">enum('Male','Female')</font></td></tr><tr><td align="left" port="faculty">faculty <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="major">major <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="phone_number">phone_number <font color="#64748b" point-size="10">varchar(20)</font></td></tr><tr><td align="left" port="email">email <font color="#64748b" point-size="10">varchar(100) NOT NULL</font></td></tr><tr><td align="left" port="role">role <font color="#64748b" point-size="10">enum('admin','student','counselor')</font></td></tr><tr><td align="left" port="profile_image">profile_image <font color="#64748b" point-size="10">varchar(255)</font></td></tr><tr><td align="left" port="status">status <font color="#64748b" point-size="10">enum('pending','active','rejected')</font></td></tr><tr><td align="left" port="approved_by">approved_by <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="approved_at">approved_at <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp NOT NULL</font></td></tr></table>>];
  "password_reset_tokens" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>password_reset_tokens</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="token_hash">token_hash <font color="#64748b" point-size="10">char(64) NOT NULL</font></td></tr><tr><td align="left" port="expires_at">expires_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr><tr><td align="left" port="used_at">used_at <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr></table>>];
  "self_help_activities" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">self_help_activities</font></td></tr></table>>];
  "booking_cancellation_requests" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">booking_cancellation_requests</font></td></tr></table>>];
  "daily_tips" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">daily_tips</font></td></tr></table>>];
  "chat_logs" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">chat_logs</font></td></tr></table>>];
  "assessment_retake_grants" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">assessment_retake_grants</font></td></tr></table>>];
  "answers" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">answers</font></td></tr></table>>];
  "assessment_sessions" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">assessment_sessions</font></td></tr></table>>];
  "diary_entries" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">diary_entries</font></td></tr></table>>];
  "monitoring_periods" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">monitoring_periods</font></td></tr></table>>];
  "notifications" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">notifications</font></td></tr></table>>];
  "counselors" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">counselors</font></td></tr></table>>];
  "chat_messages" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">chat_messages</font></td></tr></table>>];
  "students" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">students</font></td></tr></table>>];
  "system_settings" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">system_settings</font></td></tr></table>>];
  "assessment_submissions" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">assessment_submissions</font></td></tr></table>>];
  "counselor_ratings" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">counselor_ratings</font></td></tr></table>>];
  "counseling_bookings" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">counseling_bookings</font></td></tr></table>>];
  "assessment_results" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">assessment_results</font></td></tr></table>>];

  "users":"id" -> "answers" [label="user_id"];
  "users":"id" -> "assessment_results" [label="user_id"];
  "users":"id" -> "assessment_retake_grants" [label="user_id"];
  "counseling_bookings" -> "assessment_retake_grants" [label="booking_id"];
  "counselors" -> "assessment_retake_grants" [label="counselor_id"];
  "assessment_sessions" -> "assessment_retake_grants" [label="consumed_session_id"];
  "users":"id" -> "assessment_sessions" [label="user_id"];
  "assessment_submissions" -> "assessment_sessions" [label="bdi2_submission_id"];
  "assessment_submissions" -> "assessment_sessions" [label="pwb_submission_id"];
  "users":"id" -> "assessment_submissions" [label="user_id"];
  "users":"id" -> "chat_logs" [label="user_id"];
  "users":"id" -> "chat_messages" [label="user_id"];
  "users":"id" -> "chat_messages" [label="user_id"];
  "users":"id" -> "chat_messages" [label="sender_id"];
  "counselors" -> "counseling_bookings" [label="counselor_id"];
  "users":"id" -> "counseling_bookings" [label="user_id"];
  "counseling_bookings" -> "counselor_ratings" [label="booking_id"];
  "users":"id" -> "counselor_ratings" [label="user_id"];
  "counselors" -> "counselor_ratings" [label="counselor_id"];
  "users":"id" -> "counselors" [label="user_id"];
  "users":"id" -> "daily_tips" [label="created_by"];
  "counselors" -> "diary_entries" [label="shared_counselor_id"];
  "users":"id" -> "diary_entries" [label="user_id"];
  "counseling_bookings" -> "monitoring_periods" [label="booking_id"];
  "users":"id" -> "monitoring_periods" [label="user_id"];
  "counselors" -> "monitoring_periods" [label="counselor_id"];
  "users":"id" -> "notifications" [label="user_id"];
  "users":"id" -> "password_reset_tokens":"user_id" [label="user_id"];
  "users":"id" -> "self_help_activities" [label="user_id"];
  "users":"id" -> "students" [label="id"];
  "users":"id" -> "system_settings" [label="id"];
  "counseling_bookings" -> "booking_cancellation_requests" [label="booking_id"];
  "users":"id" -> "booking_cancellation_requests" [label="reviewed_by"];
}