digraph ERD {
  rankdir=TB;
  concentrate=true;
  graph [fontname="Helvetica", nodesep=0.5, ranksep=1.3, splines=polyline, bgcolor="white"];
  node [shape=plaintext, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9, fontcolor="#475569", color="#94a3b8", arrowhead=crow, arrowtail=none, dir=back];

  "faculties" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>faculties</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="name">name <font color="#64748b" point-size="10">varchar(100) NOT NULL</font></td></tr></table>>];
  "majors" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>majors</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="faculty_id"><i>faculty_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="name">name <font color="#64748b" point-size="10">varchar(100) NOT NULL</font></td></tr></table>>];

  "faculties":"id" -> "majors":"faculty_id" [label="faculty_id"];
}