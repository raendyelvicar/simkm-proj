digraph ERD {
  rankdir=TB;
  concentrate=true;
  graph [fontname="Helvetica", nodesep=0.5, ranksep=1.3, splines=polyline, bgcolor="white"];
  node [shape=plaintext, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9, fontcolor="#475569", color="#94a3b8", arrowhead=crow, arrowtail=none, dir=back];

  "students" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>students</b></font></td></tr><tr><td align="left" port="student_id"><b>🔑 student_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="id"><i>id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="student_number">student_number <font color="#64748b" point-size="10">varchar(20) NOT NULL</font></td></tr><tr><td align="left" port="study_program">study_program <font color="#64748b" point-size="10">varchar(50) NOT NULL</font></td></tr><tr><td align="left" port="faculty">faculty <font color="#64748b" point-size="10">varchar(50) NOT NULL</font></td></tr><tr><td align="left" port="gender">gender <font color="#64748b" point-size="10">enum('M','F') NOT NULL</font></td></tr><tr><td align="left" port="phone_number">phone_number <font color="#64748b" point-size="10">varchar(15)</font></td></tr></table>>];
  "system_settings" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>system_settings</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="setting_key">setting_key <font color="#64748b" point-size="10">varchar(100) NOT NULL</font></td></tr><tr><td align="left" port="setting_value">setting_value <font color="#64748b" point-size="10">text NOT NULL</font></td></tr></table>>];
  "questions" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>questions</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="question">question <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="category">category <font color="#64748b" point-size="10">varchar(50) NOT NULL</font></td></tr><tr><td align="left" port="score_weight">score_weight <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="choice_type">choice_type <font color="#64748b" point-size="10">varchar(50)</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp NOT NULL</font></td></tr></table>>];
  "answers" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>answers</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="question_id"><i>question_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="answer_value">answer_value <font color="#64748b" point-size="10">int</font></td></tr></table>>];
  "assessment_results" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_results</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="username">username <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="result_summary">result_summary <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="assessment_date">assessment_date <font color="#64748b" point-size="10">date NOT NULL</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp NOT NULL</font></td></tr><tr><td align="left" port="test_date">test_date <font color="#64748b" point-size="10">timestamp NOT NULL</font></td></tr><tr><td align="left" port="total_score">total_score <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="conclusion">conclusion <font color="#64748b" point-size="10">varchar(255)</font></td></tr><tr><td align="left" port="recommended_action">recommended_action <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="review_status">review_status <font color="#64748b" point-size="10">enum('Not Reviewed','Reviewed')</font></td></tr></table>>];
  "counselor_ratings" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>counselor_ratings</b></font></td></tr><tr><td align="left" port="rating_id"><b>🔑 rating_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="booking_id"><i>booking_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="counselor_id"><i>counselor_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="rating">rating <font color="#64748b" point-size="10">tinyint NOT NULL</font></td></tr><tr><td align="left" port="comment">comment <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp</font></td></tr></table>>];
  "counselor_certifications" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>counselor_certifications</b></font></td></tr><tr><td align="left" port="certification_id"><b>🔑 certification_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="counselor_id"><i>counselor_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="certification_name">certification_name <font color="#64748b" point-size="10">varchar(200) NOT NULL</font></td></tr><tr><td align="left" port="issuer">issuer <font color="#64748b" point-size="10">varchar(150)</font></td></tr><tr><td align="left" port="certificate_number">certificate_number <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="year">year <font color="#64748b" point-size="10">year</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp</font></td></tr></table>>];
  "diary_responses" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>diary_responses</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="diary_id"><i>diary_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="counselor_id">counselor_id <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="response">response <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp NOT NULL</font></td></tr></table>>];
  "notifications" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>notifications</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="message">message <font color="#64748b" point-size="10">varchar(255) NOT NULL</font></td></tr><tr><td align="left" port="is_read">is_read <font color="#64748b" point-size="10">tinyint(1)</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp NOT NULL</font></td></tr></table>>];
  "chat_logs" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>chat_logs</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="sender">sender <font color="#64748b" point-size="10">varchar(10)</font></td></tr><tr><td align="left" port="message">message <font color="#64748b" point-size="10">text</font></td></tr></table>>];
  "login_logs" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>login_logs</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id">user_id <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="login_time">login_time <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="ip_address">ip_address <font color="#64748b" point-size="10">varchar(50)</font></td></tr></table>>];
  "users" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">users</font></td></tr></table>>];
  "counselors" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">counselors</font></td></tr></table>>];
  "counseling_bookings" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">counseling_bookings</font></td></tr></table>>];
  "diary_entries" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">diary_entries</font></td></tr></table>>];

  "users" -> "answers":"user_id" [label="user_id"];
  "questions":"id" -> "answers":"question_id" [label="question_id"];
  "users" -> "assessment_results":"user_id" [label="user_id"];
  "users" -> "chat_logs":"user_id" [label="user_id"];
  "counselors" -> "counseling_bookings" [label="counselor_id"];
  "users" -> "counseling_bookings" [label="user_id"];
  "counselors" -> "counselor_certifications":"counselor_id" [label="counselor_id"];
  "counseling_bookings" -> "counselor_ratings":"booking_id" [label="booking_id"];
  "users" -> "counselor_ratings":"user_id" [label="user_id"];
  "counselors" -> "counselor_ratings":"counselor_id" [label="counselor_id"];
  "users" -> "counselors" [label="user_id"];
  "counselors" -> "diary_entries" [label="shared_counselor_id"];
  "users" -> "diary_entries" [label="user_id"];
  "diary_entries" -> "diary_responses":"id" [label="id"];
  "diary_entries" -> "diary_responses":"diary_id" [label="diary_id"];
  "users" -> "notifications":"user_id" [label="user_id"];
  "users" -> "students":"id" [label="id"];
  "users" -> "system_settings":"id" [label="id"];
}