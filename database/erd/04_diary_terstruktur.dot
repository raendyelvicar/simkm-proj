digraph ERD {
  rankdir=TB;
  concentrate=true;
  graph [fontname="Helvetica", nodesep=0.5, ranksep=1.3, splines=polyline, bgcolor="white"];
  node [shape=plaintext, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9, fontcolor="#475569", color="#94a3b8", arrowhead=crow, arrowtail=none, dir=back];

  "diary_entries" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>diary_entries</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="entry_date">entry_date <font color="#64748b" point-size="10">date</font></td></tr><tr><td align="left" port="title">title <font color="#64748b" point-size="10">varchar(255)</font></td></tr><tr><td align="left" port="content">content <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="situation">situation <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="initial_thoughts">initial_thoughts <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="emotions_list">emotions_list <font color="#64748b" point-size="10">json</font></td></tr><tr><td align="left" port="other_emotions">other_emotions <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="emotion_intensity">emotion_intensity <font color="#64748b" point-size="10">tinyint</font></td></tr><tr><td align="left" port="physical_reactions_list">physical_reactions_list <font color="#64748b" point-size="10">json</font></td></tr><tr><td align="left" port="other_physical_reactions">other_physical_reactions <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="behavior">behavior <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="self_reflection">self_reflection <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="gratitude_list">gratitude_list <font color="#64748b" point-size="10">json</font></td></tr><tr><td align="left" port="tomorrow_plan">tomorrow_plan <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="mood_level">mood_level <font color="#64748b" point-size="10">varchar(50)</font></td></tr><tr><td align="left" port="is_private">is_private <font color="#64748b" point-size="10">tinyint(1) NOT NULL</font></td></tr><tr><td align="left" port="shared_counselor_id"><i>shared_counselor_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">datetime</font></td></tr></table>>];
  "users" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">users</font></td></tr></table>>];
  "counselors" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">counselors</font></td></tr></table>>];
  "diary_responses" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">diary_responses</font></td></tr></table>>];

  "users" -> "counselors" [label="user_id"];
  "counselors" -> "diary_entries":"shared_counselor_id" [label="shared_counselor_id"];
  "users" -> "diary_entries":"user_id" [label="user_id"];
  "diary_entries":"id" -> "diary_responses" [label="id"];
  "diary_entries":"id" -> "diary_responses" [label="diary_id"];
}