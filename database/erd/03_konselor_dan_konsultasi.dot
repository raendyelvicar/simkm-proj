digraph ERD {
  rankdir=TB;
  concentrate=true;
  graph [fontname="Helvetica", nodesep=0.5, ranksep=1.3, splines=polyline, bgcolor="white"];
  node [shape=plaintext, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9, fontcolor="#475569", color="#94a3b8", arrowhead=crow, arrowtail=none, dir=back];

  "counselors" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>counselors</b></font></td></tr><tr><td align="left" port="counselor_id"><b>🔑 counselor_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="registration_number">registration_number <font color="#64748b" point-size="10">varchar(50) NOT NULL</font></td></tr><tr><td align="left" port="profession">profession <font color="#64748b" point-size="10">enum('Psychologist','Counselor','Psychiatrist') NOT NULL</font></td></tr><tr><td align="left" port="specialization">specialization <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="education">education <font color="#64748b" point-size="10">varchar(150)</font></td></tr><tr><td align="left" port="experience_years">experience_years <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="languages">languages <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="consultation_fee">consultation_fee <font color="#64748b" point-size="10">decimal(12,2)</font></td></tr><tr><td align="left" port="session_duration">session_duration <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="consultation_method">consultation_method <font color="#64748b" point-size="10">enum('Online','Offline','Hybrid')</font></td></tr><tr><td align="left" port="profile_photo">profile_photo <font color="#64748b" point-size="10">varchar(255)</font></td></tr><tr><td align="left" port="biography">biography <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="verification_status">verification_status <font color="#64748b" point-size="10">tinyint(1)</font></td></tr><tr><td align="left" port="is_active">is_active <font color="#64748b" point-size="10">tinyint(1)</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp</font></td></tr><tr><td align="left" port="updated_at">updated_at <font color="#64748b" point-size="10">timestamp</font></td></tr></table>>];
  "counselor_schedules" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>counselor_schedules</b></font></td></tr><tr><td align="left" port="schedule_id"><b>🔑 schedule_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="counselor_id"><i>counselor_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="date">date <font color="#64748b" point-size="10">date NOT NULL</font></td></tr><tr><td align="left" port="start_time">start_time <font color="#64748b" point-size="10">time NOT NULL</font></td></tr><tr><td align="left" port="end_time">end_time <font color="#64748b" point-size="10">time NOT NULL</font></td></tr><tr><td align="left" port="quota">quota <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="is_active">is_active <font color="#64748b" point-size="10">tinyint(1)</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp</font></td></tr></table>>];
  "counseling_bookings" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>counseling_bookings</b></font></td></tr><tr><td align="left" port="booking_id"><b>🔑 booking_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="counselor_id"><i>counselor_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="schedule_id"><i>schedule_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="date">date <font color="#64748b" point-size="10">date NOT NULL</font></td></tr><tr><td align="left" port="start_time">start_time <font color="#64748b" point-size="10">time NOT NULL</font></td></tr><tr><td align="left" port="end_time">end_time <font color="#64748b" point-size="10">time NOT NULL</font></td></tr><tr><td align="left" port="complaint">complaint <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="status">status <font color="#64748b" point-size="10">enum('Pending','Confirmed','Completed','Cancelled','No Show')</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp</font></td></tr></table>>];
  "booking_cancellation_requests" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>booking_cancellation_requests</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="booking_id"><i>booking_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="previous_status">previous_status <font color="#64748b" point-size="10">enum('Pending','Confirmed') NOT NULL</font></td></tr><tr><td align="left" port="reason">reason <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="status">status <font color="#64748b" point-size="10">enum('Pending','Approved','Rejected') NOT NULL</font></td></tr><tr><td align="left" port="admin_notes">admin_notes <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="reviewed_by"><i>reviewed_by</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="reviewed_at">reviewed_at <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr></table>>];
  "monitoring_periods" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>monitoring_periods</b></font></td></tr><tr><td align="left" port="monitoring_id"><b>🔑 monitoring_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="booking_id"><i>booking_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="counselor_id"><i>counselor_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="start_date">start_date <font color="#64748b" point-size="10">date NOT NULL</font></td></tr><tr><td align="left" port="end_date">end_date <font color="#64748b" point-size="10">date NOT NULL</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp</font></td></tr></table>>];
  "counseling_sessions" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>counseling_sessions</b></font></td></tr><tr><td align="left" port="session_id"><b>🔑 session_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="booking_id"><i>booking_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="counselor_notes">counselor_notes <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="recommendation">recommendation <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="follow_up">follow_up <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="duration">duration <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="completed_at">completed_at <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp</font></td></tr></table>>];
  "chat_messages" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>chat_messages</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="sender_id"><i>sender_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="receiver_id">receiver_id <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="message">message <font color="#64748b" point-size="10">text NOT NULL</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr><tr><td align="left" port="is_read">is_read <font color="#64748b" point-size="10">tinyint(1)</font></td></tr></table>>];
  "users" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">users</font></td></tr></table>>];
  "diary_entries" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">diary_entries</font></td></tr></table>>];
  "assessment_retake_grants" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">assessment_retake_grants</font></td></tr></table>>];
  "counselor_ratings" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">counselor_ratings</font></td></tr></table>>];
  "counselor_certifications" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">counselor_certifications</font></td></tr></table>>];

  "users" -> "assessment_retake_grants" [label="user_id"];
  "counseling_bookings":"booking_id" -> "assessment_retake_grants" [label="booking_id"];
  "counselors":"counselor_id" -> "assessment_retake_grants" [label="counselor_id"];
  "users" -> "chat_messages":"user_id" [label="user_id"];
  "users" -> "chat_messages":"user_id" [label="user_id"];
  "users" -> "chat_messages":"sender_id" [label="sender_id"];
  "counselor_schedules":"schedule_id" -> "counseling_bookings":"schedule_id" [label="schedule_id"];
  "counselors":"counselor_id" -> "counseling_bookings":"counselor_id" [label="counselor_id"];
  "users" -> "counseling_bookings":"user_id" [label="user_id"];
  "counseling_bookings":"booking_id" -> "counseling_sessions":"booking_id" [label="booking_id"];
  "counselors":"counselor_id" -> "counselor_certifications" [label="counselor_id"];
  "counseling_bookings":"booking_id" -> "counselor_ratings" [label="booking_id"];
  "users" -> "counselor_ratings" [label="user_id"];
  "counselors":"counselor_id" -> "counselor_ratings" [label="counselor_id"];
  "counselors":"counselor_id" -> "counselor_schedules":"counselor_id" [label="counselor_id"];
  "users" -> "counselors":"user_id" [label="user_id"];
  "counselors":"counselor_id" -> "diary_entries" [label="shared_counselor_id"];
  "users" -> "diary_entries" [label="user_id"];
  "counseling_bookings":"booking_id" -> "monitoring_periods":"booking_id" [label="booking_id"];
  "users" -> "monitoring_periods":"user_id" [label="user_id"];
  "counselors":"counselor_id" -> "monitoring_periods":"counselor_id" [label="counselor_id"];
  "counseling_bookings":"booking_id" -> "booking_cancellation_requests":"booking_id" [label="booking_id"];
  "users" -> "booking_cancellation_requests":"reviewed_by" [label="reviewed_by"];
}