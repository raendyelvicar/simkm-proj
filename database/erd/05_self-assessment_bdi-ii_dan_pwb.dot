digraph ERD {
  rankdir=TB;
  concentrate=true;
  graph [fontname="Helvetica", nodesep=0.5, ranksep=1.3, splines=polyline, bgcolor="white"];
  node [shape=plaintext, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9, fontcolor="#475569", color="#94a3b8", arrowhead=crow, arrowtail=none, dir=back];

  "assessment_questions" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_questions</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="type">type <font color="#64748b" point-size="10">enum('bdi2','pwb') NOT NULL</font></td></tr><tr><td align="left" port="order_no">order_no <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="question_text">question_text <font color="#64748b" point-size="10">varchar(500) NOT NULL</font></td></tr><tr><td align="left" port="dimension">dimension <font color="#64748b" point-size="10">varchar(50)</font></td></tr><tr><td align="left" port="is_reverse_scored">is_reverse_scored <font color="#64748b" point-size="10">tinyint(1) NOT NULL</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr></table>>];
  "assessment_choices" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_choices</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="question_id"><i>question_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="order_no">order_no <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="label">label <font color="#64748b" point-size="10">varchar(255) NOT NULL</font></td></tr><tr><td align="left" port="score_value">score_value <font color="#64748b" point-size="10">int NOT NULL</font></td></tr></table>>];
  "assessment_sessions" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_sessions</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="status">status <font color="#64748b" point-size="10">enum('in_progress','completed','timed_out') NOT NULL</font></td></tr><tr><td align="left" port="time_limit_seconds">time_limit_seconds <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="started_at">started_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr><tr><td align="left" port="expires_at">expires_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr><tr><td align="left" port="last_seen_question_id">last_seen_question_id <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="bdi2_submission_id"><i>bdi2_submission_id</i> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="pwb_submission_id"><i>pwb_submission_id</i> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="finalized_at">finalized_at <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr></table>>];
  "assessment_session_answers" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_session_answers</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="session_id"><i>session_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="question_id"><i>question_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="choice_id"><i>choice_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="score_value">score_value <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="answered_at">answered_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr></table>>];
  "assessment_submissions" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_submissions</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="type">type <font color="#64748b" point-size="10">enum('bdi2','pwb') NOT NULL</font></td></tr><tr><td align="left" port="total_score">total_score <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="max_score">max_score <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="category">category <font color="#64748b" point-size="10">varchar(50) NOT NULL</font></td></tr><tr><td align="left" port="category_percentage">category_percentage <font color="#64748b" point-size="10">decimal(5,2)</font></td></tr><tr><td align="left" port="is_timed_out">is_timed_out <font color="#64748b" point-size="10">tinyint(1) NOT NULL</font></td></tr><tr><td align="left" port="dimension_scores">dimension_scores <font color="#64748b" point-size="10">json</font></td></tr><tr><td align="left" port="submitted_at">submitted_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr></table>>];
  "assessment_answers" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_answers</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="submission_id"><i>submission_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="question_id"><i>question_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="choice_id"><i>choice_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="score_value">score_value <font color="#64748b" point-size="10">int NOT NULL</font></td></tr></table>>];
  "assessment_retake_grants" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_retake_grants</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="booking_id"><i>booking_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="counselor_id"><i>counselor_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="granted_at">granted_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr><tr><td align="left" port="consumed_at">consumed_at <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="consumed_session_id"><i>consumed_session_id</i> <font color="#64748b" point-size="10">int unsigned</font></td></tr></table>>];
  "users" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">users</font></td></tr></table>>];
  "counselors" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">counselors</font></td></tr></table>>];
  "counseling_bookings" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">counseling_bookings</font></td></tr></table>>];

  "assessment_questions":"id" -> "assessment_answers":"question_id" [label="question_id"];
  "assessment_choices":"id" -> "assessment_answers":"choice_id" [label="choice_id"];
  "assessment_submissions":"id" -> "assessment_answers":"submission_id" [label="submission_id"];
  "assessment_questions":"id" -> "assessment_choices":"question_id" [label="question_id"];
  "users" -> "assessment_retake_grants":"user_id" [label="user_id"];
  "counseling_bookings" -> "assessment_retake_grants":"booking_id" [label="booking_id"];
  "counselors" -> "assessment_retake_grants":"counselor_id" [label="counselor_id"];
  "assessment_sessions":"id" -> "assessment_retake_grants":"consumed_session_id" [label="consumed_session_id"];
  "assessment_choices":"id" -> "assessment_session_answers":"choice_id" [label="choice_id"];
  "assessment_questions":"id" -> "assessment_session_answers":"question_id" [label="question_id"];
  "assessment_sessions":"id" -> "assessment_session_answers":"session_id" [label="session_id"];
  "users" -> "assessment_sessions":"user_id" [label="user_id"];
  "assessment_submissions":"id" -> "assessment_sessions":"bdi2_submission_id" [label="bdi2_submission_id"];
  "assessment_submissions":"id" -> "assessment_sessions":"pwb_submission_id" [label="pwb_submission_id"];
  "users" -> "assessment_submissions":"user_id" [label="user_id"];
  "counselors" -> "counseling_bookings" [label="counselor_id"];
  "users" -> "counseling_bookings" [label="user_id"];
  "users" -> "counselors" [label="user_id"];
}