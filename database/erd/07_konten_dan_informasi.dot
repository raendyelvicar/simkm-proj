digraph ERD {
  rankdir=TB;
  concentrate=true;
  graph [fontname="Helvetica", nodesep=0.5, ranksep=1.3, splines=polyline, bgcolor="white"];
  node [shape=plaintext, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9, fontcolor="#475569", color="#94a3b8", arrowhead=crow, arrowtail=none, dir=back];

  "articles" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>articles</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="admin_id">admin_id <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="title">title <font color="#64748b" point-size="10">varchar(255) NOT NULL</font></td></tr><tr><td align="left" port="content">content <font color="#64748b" point-size="10">text NOT NULL</font></td></tr><tr><td align="left" port="category">category <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="image">image <font color="#64748b" point-size="10">varchar(255)</font></td></tr><tr><td align="left" port="tags">tags <font color="#64748b" point-size="10">varchar(255)</font></td></tr><tr><td align="left" port="published_at">published_at <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="user_id">user_id <font color="#64748b" point-size="10">int NOT NULL</font></td></tr></table>>];
  "daily_tips" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>daily_tips</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="content">content <font color="#64748b" point-size="10">text NOT NULL</font></td></tr><tr><td align="left" port="is_active">is_active <font color="#64748b" point-size="10">tinyint(1) NOT NULL</font></td></tr><tr><td align="left" port="created_by"><i>created_by</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr><tr><td align="left" port="updated_at">updated_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr><tr><td align="left" port="title">title <font color="#64748b" point-size="10">text</font></td></tr></table>>];
  "users" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">users</font></td></tr></table>>];

  "users" -> "daily_tips":"created_by" [label="created_by"];
}