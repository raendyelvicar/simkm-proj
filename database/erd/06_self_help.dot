digraph ERD {
  rankdir=TB;
  concentrate=true;
  graph [fontname="Helvetica", nodesep=0.5, ranksep=1.3, splines=polyline, bgcolor="white"];
  node [shape=plaintext, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9, fontcolor="#475569", color="#94a3b8", arrowhead=crow, arrowtail=none, dir=back];

  "self_help_activities" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>self_help_activities</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="title">title <font color="#64748b" point-size="10">varchar(150) NOT NULL</font></td></tr><tr><td align="left" port="description">description <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="planned_date">planned_date <font color="#64748b" point-size="10">date NOT NULL</font></td></tr><tr><td align="left" port="mood_before">mood_before <font color="#64748b" point-size="10">tinyint</font></td></tr><tr><td align="left" port="mood_after">mood_after <font color="#64748b" point-size="10">tinyint</font></td></tr><tr><td align="left" port="status">status <font color="#64748b" point-size="10">enum('planned','done','skipped') NOT NULL</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr><tr><td align="left" port="updated_at">updated_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr></table>>];
  "users" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="6"><tr><td bgcolor="#cbd5e1"><font color="#1e293b" point-size="12">users</font></td></tr></table>>];

  "users" -> "self_help_activities":"user_id" [label="user_id"];
}