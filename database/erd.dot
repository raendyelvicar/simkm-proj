digraph ERD {
  rankdir=TB;
  concentrate=true;
  graph [fontname="Helvetica", nodesep=0.5, ranksep=1.3, splines=polyline, bgcolor="white"];
  node [shape=plaintext, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9, fontcolor="#475569", color="#94a3b8", arrowhead=crow, arrowtail=none, dir=back];

  "answers" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>answers</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="question_id"><i>question_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="answer_value">answer_value <font color="#64748b" point-size="10">int</font></td></tr></table>>];
  "app_settings" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>app_settings</b></font></td></tr><tr><td align="left" port="setting_key"><b>🔑 setting_key</b> <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="setting_value">setting_value <font color="#64748b" point-size="10">varchar(255) NOT NULL</font></td></tr><tr><td align="left" port="updated_at">updated_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr></table>>];
  "articles" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>articles</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="admin_id">admin_id <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="title">title <font color="#64748b" point-size="10">varchar(255) NOT NULL</font></td></tr><tr><td align="left" port="content">content <font color="#64748b" point-size="10">text NOT NULL</font></td></tr><tr><td align="left" port="category">category <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="image">image <font color="#64748b" point-size="10">varchar(255)</font></td></tr><tr><td align="left" port="tags">tags <font color="#64748b" point-size="10">varchar(255)</font></td></tr><tr><td align="left" port="published_at">published_at <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="user_id">user_id <font color="#64748b" point-size="10">int NOT NULL</font></td></tr></table>>];
  "assessment_answers" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_answers</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="submission_id"><i>submission_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="question_id"><i>question_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="choice_id"><i>choice_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="score_value">score_value <font color="#64748b" point-size="10">int NOT NULL</font></td></tr></table>>];
  "assessment_choices" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_choices</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="question_id"><i>question_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="order_no">order_no <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="label">label <font color="#64748b" point-size="10">varchar(255) NOT NULL</font></td></tr><tr><td align="left" port="score_value">score_value <font color="#64748b" point-size="10">int NOT NULL</font></td></tr></table>>];
  "assessment_questions" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_questions</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="type">type <font color="#64748b" point-size="10">enum('bdi2','pwb') NOT NULL</font></td></tr><tr><td align="left" port="order_no">order_no <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="question_text">question_text <font color="#64748b" point-size="10">varchar(500) NOT NULL</font></td></tr><tr><td align="left" port="dimension">dimension <font color="#64748b" point-size="10">varchar(50)</font></td></tr><tr><td align="left" port="is_reverse_scored">is_reverse_scored <font color="#64748b" point-size="10">tinyint(1) NOT NULL</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr></table>>];
  "assessment_results" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_results</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="username">username <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="result_summary">result_summary <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="assessment_date">assessment_date <font color="#64748b" point-size="10">date NOT NULL</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp NOT NULL</font></td></tr><tr><td align="left" port="test_date">test_date <font color="#64748b" point-size="10">timestamp NOT NULL</font></td></tr><tr><td align="left" port="total_score">total_score <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="conclusion">conclusion <font color="#64748b" point-size="10">varchar(255)</font></td></tr><tr><td align="left" port="recommended_action">recommended_action <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="review_status">review_status <font color="#64748b" point-size="10">enum('Not Reviewed','Reviewed')</font></td></tr></table>>];
  "assessment_retake_grants" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_retake_grants</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="booking_id"><i>booking_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="counselor_id"><i>counselor_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="granted_at">granted_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr><tr><td align="left" port="consumed_at">consumed_at <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="consumed_session_id"><i>consumed_session_id</i> <font color="#64748b" point-size="10">int unsigned</font></td></tr></table>>];
  "assessment_session_answers" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_session_answers</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="session_id"><i>session_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="question_id"><i>question_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="choice_id"><i>choice_id</i> <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="score_value">score_value <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="answered_at">answered_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr></table>>];
  "assessment_sessions" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_sessions</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="status">status <font color="#64748b" point-size="10">enum('in_progress','completed','timed_out') NOT NULL</font></td></tr><tr><td align="left" port="time_limit_seconds">time_limit_seconds <font color="#64748b" point-size="10">int unsigned NOT NULL</font></td></tr><tr><td align="left" port="started_at">started_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr><tr><td align="left" port="expires_at">expires_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr><tr><td align="left" port="last_seen_question_id">last_seen_question_id <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="bdi2_submission_id"><i>bdi2_submission_id</i> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="pwb_submission_id"><i>pwb_submission_id</i> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="finalized_at">finalized_at <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr></table>>];
  "assessment_submissions" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>assessment_submissions</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int unsigned</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="type">type <font color="#64748b" point-size="10">enum('bdi2','pwb') NOT NULL</font></td></tr><tr><td align="left" port="total_score">total_score <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="max_score">max_score <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="category">category <font color="#64748b" point-size="10">varchar(50) NOT NULL</font></td></tr><tr><td align="left" port="category_percentage">category_percentage <font color="#64748b" point-size="10">decimal(5,2)</font></td></tr><tr><td align="left" port="is_timed_out">is_timed_out <font color="#64748b" point-size="10">tinyint(1) NOT NULL</font></td></tr><tr><td align="left" port="dimension_scores">dimension_scores <font color="#64748b" point-size="10">json</font></td></tr><tr><td align="left" port="submitted_at">submitted_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr></table>>];
  "chat_logs" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>chat_logs</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="sender">sender <font color="#64748b" point-size="10">varchar(10)</font></td></tr><tr><td align="left" port="message">message <font color="#64748b" point-size="10">text</font></td></tr></table>>];
  "chat_messages" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>chat_messages</b></font></td></tr><tr><td align="left" port="id"><b>🔑 id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="sender_id"><i>sender_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="receiver_id">receiver_id <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="message">message <font color="#64748b" point-size="10">text NOT NULL</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">datetime NOT NULL</font></td></tr><tr><td align="left" port="is_read">is_read <font color="#64748b" point-size="10">tinyint(1)</font></td></tr></table>>];
  "counseling_bookings" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>counseling_bookings</b></font></td></tr><tr><td align="left" port="booking_id"><b>🔑 booking_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="counselor_id"><i>counselor_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="schedule_id"><i>schedule_id</i> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="date">date <font color="#64748b" point-size="10">date NOT NULL</font></td></tr><tr><td align="left" port="start_time">start_time <font color="#64748b" point-size="10">time NOT NULL</font></td></tr><tr><td align="left" port="end_time">end_time <font color="#64748b" point-size="10">time NOT NULL</font></td></tr><tr><td align="left" port="complaint">complaint <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="status">status <font color="#64748b" point-size="10">enum('Pending','Confirmed','Completed','Cancelled','No Show')</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp</font></td></tr></table>>];
  "counseling_sessions" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>counseling_sessions</b></font></td></tr><tr><td align="left" port="session_id"><b>🔑 session_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="booking_id"><i>booking_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="counselor_notes">counselor_notes <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="recommendation">recommendation <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="follow_up">follow_up <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="duration">duration <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="completed_at">completed_at <font color="#64748b" point-size="10">datetime</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp</font></td></tr></table>>];
  "counselor_certifications" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>counselor_certifications</b></font></td></tr><tr><td align="left" port="certification_id"><b>🔑 certification_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="counselor_id"><i>counselor_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="certification_name">certification_name <font color="#64748b" point-size="10">varchar(200) NOT NULL</font></td></tr><tr><td align="left" port="issuer">issuer <font color="#64748b" point-size="10">varchar(150)</font></td></tr><tr><td align="left" port="certificate_number">certificate_number <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="year">year <font color="#64748b" point-size="10">year</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp</font></td></tr></table>>];
  "counselor_ratings" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>counselor_ratings</b></font></td></tr><tr><td align="left" port="rating_id"><b>🔑 rating_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="booking_id"><i>booking_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="counselor_id"><i>counselor_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="rating">rating <font color="#64748b" point-size="10">tinyint NOT NULL</font></td></tr><tr><td align="left" port="comment">comment <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp</font></td></tr></table>>];
  "counselor_schedules" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>counselor_schedules</b></font></td></tr><tr><td align="left" port="schedule_id"><b>🔑 schedule_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="counselor_id"><i>counselor_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="date">date <font color="#64748b" point-size="10">date NOT NULL</font></td></tr><tr><td align="left" port="start_time">start_time <font color="#64748b" point-size="10">time NOT NULL</font></td></tr><tr><td align="left" port="end_time">end_time <font color="#64748b" point-size="10">time NOT NULL</font></td></tr><tr><td align="left" port="quota">quota <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="is_active">is_active <font color="#64748b" point-size="10">tinyint(1)</font></td></tr><tr><td align="left" port="created_at">created_at <font color="#64748b" point-size="10">timestamp</font></td></tr></table>>];
  "counselors" [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5"><tr><td bgcolor="#1e293b" align="center"><font color="white" point-size="13"><b>counselors</b></font></td></tr><tr><td align="left" port="counselor_id"><b>🔑 counselor_id</b> <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="user_id"><i>user_id</i> <font color="#64748b" point-size="10">int NOT NULL</font></td></tr><tr><td align="left" port="registration_number">registration_number <font color="#64748b" point-size="10">varchar(50) NOT NULL</font></td></tr><tr><td align="left" port="profession">profession <font color="#64748b" point-size="10">enum('Psychologist','Counselor','Psychiatrist') NOT NULL</font></td></tr><tr><td align="left" port="specialization">specialization <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="education">education <font color="#64748b" point-size="10">varchar(150)</font></td></tr><tr><td align="left" port="experience_years">experience_years <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="languages">languages <font color="#64748b" point-size="10">varchar(100)</font></td></tr><tr><td align="left" port="consultation_fee">consultation_fee <font color="#64748b" point-size="10">decimal(12,2)</font></td></tr><tr><td align="left" port="session_duration">session_duration <font color="#64748b" point-size="10">int</font></td></tr><tr><td align="left" port="consultation_method">consultation_method <font color="#64748b" point-size="10">enum('Online','Offline','Hybrid')</font></td></tr><tr><td align="left" port="profile_photo">profile_photo <font color="#64748b" point-size="10">varchar(255)</font></td></tr><tr><td align="left" port="biography">biography <font color="#64748b" point-size="10">text</font></td></tr><tr><td align="left" port="verification_status">verification_status <font color="#64748b" point-size="10">tinyint(1)</font></td></tr><tr><td align=